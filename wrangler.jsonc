{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "antami",
  "compatibility_date": "2026-05-01",
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "antami.ae", "custom_domain": true },
    { "pattern": "www.antami.ae", "custom_domain": true }
  ]
}
